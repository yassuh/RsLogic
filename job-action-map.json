  "sdk_steps": {
    "sdk_node_connect_user": {
      "kind": "sdk",
      "method": "client.node.connect_user()",
      "requires_params": [],
      "example_result": "node connection object"
    },
    "sdk_node_disconnect_user": {
      "kind": "sdk",
      "method": "client.node.disconnect_user()",
      "requires_params": []
    },
    "sdk_project_create": {
      "kind": "sdk",
      "method": "client.project.create()",
      "requires_params": []
    },
    "sdk_project_open": {
      "kind": "sdk",
      "method": "client.project.open(guid, name=None)",
      "params": {
        "guid": "string (required)",
        "name": "string (optional)"
      }
    },
    "sdk_project_close": {
      "kind": "sdk",
      "method": "client.project.close()",
      "requires_params": []
    },
    "sdk_project_disconnect": {
      "kind": "sdk",
      "method": "client.project.disconnect()",
      "requires_params": []
    },
    "sdk_project_save": {
      "kind": "sdk",
      "method": "client.project.save(path)",
      "params": {
        "path": "string"
      }
    },
    "sdk_project_command": {
      "kind": "sdk",
      "method": "client.project.command(name, params=None, conditional_tag=None, use_post=False, encoded=None, post_body=None)",
      "params": {
        "name": "string",
        "params": "dict",
        "conditional_tag": "string",
        "use_post": "bool",
        "encoded": "string",
        "post_body": "dict"
      }
    },
    "sdk_project_commandgroup": {
      "kind": "sdk",
      "method": "client.project.command_group(command_calls)",
      "params": {
        "command_calls": "dict"
      }
    },
