      "requires_params": []
    }
  },
  "dynamic_rules": [
    {
      "action_regex": "^sdk_node_[a-z_]+$",
      "description": "Any action starting with sdk_node_ is resolved to client.node.<method> using underscore and camelCase fallbacks."
    },
    {
      "action_regex": "^sdk_project_[a-z_]+$",
      "description": "Any action starting with sdk_project_ is resolved to client.project.<method> using underscore and camelCase fallbacks."
    },
    {
      "action_regex": "^sdk_[a-z_]+$",
      "description": "Generic sdk_* actions are also accepted and resolved against available client sdk methods."
    }
  ],
  "dispatcher": {
    "location": "rslogic.client.executor",
    "class": "StepExecutor.execute",
    "mapping_file": "rslogic/client/executor.py",
    "file_step_prefix": "if kind == \"file\"",
    "sdk_fallback": "if action not in explicit mapping and action starts with sdk_"
  }
}
